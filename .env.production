# 开发环境配置
NODE_ENV=production
# 接口前缀
API_PREFIX=api
# 端口号
APP_PORT=3001
# app名称
APP_NAME="NestJS API 生产环境"

# 数据库地址
DATABASE_HOST=localhost  
# 数据库端口
DATABASE_PORT=3306
# 数据库登录名
DATABASE_USERNAME=root
# 数据库登录密码
DATABASE_PASSWORD=123
# 数据库名字
DATABASE_NAME=tw_nestjs
# 根据实体自动创建数据库表， 生产环境建议关闭
DATABASE_SYNCHRONIZE=false
# 最大链接数
DATABASE_MAX_CONNECTIONS=100

# Redis配置
REDIS_HOSE=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=123